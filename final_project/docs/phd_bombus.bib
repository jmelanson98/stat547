@article{weir_estimating_1984,
	title = {Estimating F-Statistics for the Analysis of Population Structure},
	volume = {38},
	issn = {0014-3820},
	url = {https://www.jstor.org/stable/2408641},
	doi = {10.2307/2408641},
	abstract = {Formulae are given for estimators for the parameters F, ?, f (F$_{\textrm{{IT}}}$, F$_{\textrm{{ST}}}$, F$_{\textrm{{IS}}}$) of population structure. As with all such estimators, ratios are used so that their properties are not known exactly, but they have been found to perform satisfactorily in simulations. Unlike the estimators in general use, the formulae do not make assumptions concerning numbers of populations, sample sizes, or heterozygote frequencies. As such, they are suited to small data sets and will aid the comparisons of results of different investigators. A simple weighting procedure is suggested for combining information over alleles and loci, and sample variances may be estimated by a jackknife procedure.},
	pages = {1358--1370},
	number = {6},
	journaltitle = {Evolution},
	author = {Weir, B. S. and Cockerham, C. Clark},
	urldate = {2025-06-26},
	date = {1984},
}

