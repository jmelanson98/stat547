	title = {First records of the Common Eastern Bumble Bee, Bombus impatiens Cresson (Hymenoptera: Apidae, Apinae, Bombini) from the Prairies Ecozone in Canada},
	volume = {7},
	rights = {2019Kirsten Palmier, Cory Sheffield},
