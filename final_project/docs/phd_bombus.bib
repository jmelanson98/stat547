	url = {https://bioone.org/journals/transactions-of-the-american-entomological-society/volume-132/issue-3/0002-8320_2006_132_285_FROTIB_2.0.CO_2/First-record-of-the-invasive-bumblebee-Bombus-terrestris-L-Hymenoptera/10.3157/0002-8320(2006)132[285:FROTIB]2.0.CO;2.full},
