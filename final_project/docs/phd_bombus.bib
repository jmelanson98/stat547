	url = {https://bdj.pensoft.net/article/30953/},
	doi = {10.3897/BDJ.7.e30953},
	shorttitle = {First records of the Common Eastern Bumble Bee, Bombus impatiens Cresson (Hymenoptera},
	abstract = {Here we report on recent captures of B. impatiens workers and males from south-eastern Alberta and suggest that these specimens escaped from nearby commercial greenhouses. The risk that the presence and looming establishment of this species has on native bumble bees in the Canadian prairies is discussed.},
	pages = {e30953},
